# Copy this file to ssl_backend/.env and replace placeholders.
# AD CS registration requires a non-default secret (see ADCS / DJANGO keys below).

DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-40-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

POSTGRES_DB=ssl_lifecycle
POSTGRES_USER=ssl_user
POSTGRES_PASSWORD=ssl_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173

# AD CS: encrypts WinRM passwords in the database. Must NOT be the literal
# "ssl-lifecycle-change-me". If unset, Django SECRET_KEY is used — so set either
# DJANGO_SECRET_KEY above or this dedicated key:
ADCS_ENCRYPTION_KEY=replace-with-long-random-secret

# Local testing only: skip AES for AD CS passwords (stored with an obvious prefix).
# When unset, plaintext mode follows Django DEBUG (on for typical local runserver).
# Set ADCS_PLAINTEXT_PASSWORDS_DEV=false to require AES + DJANGO_SECRET_KEY / ADCS_ENCRYPTION_KEY.
# Never rely on plaintext in production (DEBUG=false).
ADCS_PLAINTEXT_PASSWORDS_DEV=true

# SMTP / email configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=alerts@example.com
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=CertEye Alerts <alerts@example.com>

# Additional alert recipients (comma-separated)
ALERT_RECIPIENTS=security@example.com,ops@example.com
